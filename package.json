{
  "name": "hivekit",
  "version": "1.0.0",
  "description": "Declare what done means — hivekit builds until it's true. Reference compiler for HIVE.md (intent-as-source for AI agents)",
  "type": "module",
  "bin": {
    "hivekit": "./bin/hivekit",
    "harness": "./bin/harness"
  },
  "scripts": {
    "build": "tsc && rm -rf dist/prompts && cp -r src/prompts dist/prompts",
    "prepare": "npm run build",
    "test": "npm run build && node --test test/*.test.mjs",
    "dev": "env -u ANTHROPIC_API_KEY tsx src/index.ts",
    "start": "env -u ANTHROPIC_API_KEY node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.90"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
